# Java Study App Configuration
# Copy this file to .env and customize values as needed

# ─── Ollama Configuration ───────────────────────────────────────────────────
# The AI model used for grading written answers
# Options: qwen2.5:7b (fast, lighter), qwen2.5:14b (balanced), qwen2.5:32b (best quality)
OLLAMA_MODEL=qwen2.5:14b

# Ollama API base URL (default: localhost)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Server Configuration ───────────────────────────────────────────────────
# Host to bind to. Use:
#   127.0.0.1 or localhost = local access only (more secure)
#   0.0.0.0 = accessible from other machines on your network
SERVER_HOST=127.0.0.1

# Port to run the web server on (default: 5000)
SERVER_PORT=5000

# ─── Data Storage ──────────────────────────────────────────────────────────
# JSON file for saving user progress and checkpoints
SAVE_FILE=checkpoints.json

# ─── Optional: Debug Mode ──────────────────────────────────────────────────
# Set to true for verbose logging (default: false)
DEBUG_MODE=false

# ─── Optional: Auto-launch Browser ─────────────────────────────────────────
# Set to false if you want to manually open the browser (default: true)
AUTO_OPEN_BROWSER=true
